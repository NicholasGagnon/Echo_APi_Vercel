{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/dev"
      ],
      "outFiles": [
        "${workspaceFolder}/dev/out/**/*.js"
      ],
      "preLaunchTask": "build dev extension"
    }
  ]
}
